# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection String
# For local: mongodb://localhost:27017/aetheria_heights
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/aetheria_heights?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/aetheria_heights

# JWT Secret Key (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-to-something-strong

# Email Configuration (Gmail)
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# API URL (for frontend requests)
VITE_API_URL=http://localhost:3001
